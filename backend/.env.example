MONGO_URI=your_mongodb_uri  
PORT=your_port  
API_URL=http://localhost:5001/api
JWT_SECRET=your_jwt_secret  
JWT_EXPIRES_IN=your_jwt_expires_in  

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@campusor.com

# Legacy Resend Configuration (deprecated - use SMTP above)
# RESEND_API_KEY=your_resend_api_key
# FROM_EMAIL=onboarding@resend.dev
# RESEND_DELAYED_TEMPLATE_ID=your_delayed_template_id
# RESEND_ALMOST_READY_TEMPLATE_ID=your_almost_ready_template_id
# RESEND_READY_TEMPLATE_ID=your_ready_template_id

FRONTEND_URL=http://localhost:5173

REDIS_URL=redis://localhost:6379

# Queue Join Rate Limiting
QUEUE_JOIN_COOLDOWN_SECONDS=120
QUEUE_JOIN_RATE_LIMIT_PER_MIN=3
QUEUE_JOIN_RATE_LIMIT_PER_HOUR=20
TOKEN_EXPIRY_MINUTES=5

# Token Expiry
TOKEN_EXPIRY_MINUTES=5